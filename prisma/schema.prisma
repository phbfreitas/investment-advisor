// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FinancialProfile {
  id              String   @id @default(uuid())
  strategy        String?  // Overall investment philosophy
  riskTolerance   String?  // e.g., Low, Medium, High, "Cautious but growth-focused"
  goals           String?  // Short/long term goals
  monthlyIncome   Float?
  monthlyExpenses Float?
  cashReserves    Float?
  updatedAt       DateTime @updatedAt
  
  // A profile can have many assets
  assets          Asset[]
}

model Asset {
  id               String   @id @default(uuid())
  profileId        String
  profile          FinancialProfile @relation(fields: [profileId], references: [id])
  
  ticker           String   // e.g., AAPL, VOO. Or "Real Estate" for manual
  name             String
  assetType        String   // "STOCK", "ETF", "CRYPTO", "CASH", "OTHER"
  quantity         Float
  averageCost      Float
  currentPrice     Float?   // Optional: Updated via API
  currency         String   @default("USD")
  
  institution      String?  // e.g., Wealthsimple, Fidelity (to track source)
  isManuallyAdded  Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}
